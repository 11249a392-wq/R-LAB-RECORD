Question 1: University Course Enrollment (Updated Data)
# Data
departments <- c("Civil", "AI", "Biotech", "Chemical")
students <- c(95, 140, 70, 55)
# Pie Chart
pie(
  students,
  labels = departments,
  main = "Enrollment Distribution",
  col = c("lightblue", "lightcoral", "lightgreen", "lightyellow")
)
# Bar Chart
barplot(
  students,
  names.arg = departments,
  main = "Students per Department",
  xlab = "Department",
  ylab = "Students Count",
  col = c("lightblue", "lightcoral", "lightgreen", "lightyellow")
)

Question 2: Retail Store Sales Distribution (Updated Data)
# Data
category <- c("Groceries", "Furniture", "Toys", "Footwear")
sales <- c(90000, 120000, 45000, 60000)

# Pie Chart
pie(
  sales,
  labels = category,
  main = "Sales Distribution",
  col = rainbow(length(category))
)
# Bar Chart
barplot(
  sales,
  names.arg = category,
  main = "Sales by Category",
  xlab = "Category",
  ylab = "Sales (₹)",
  col = rainbow(length(category))
)

