Question 1: School Student Marks Analysis (Updated Data)
students <- data.frame(
  Name = c("Dev","Priya","Manoj","Keerthi","Vijay","Pooja","Ramesh","Divya","Nitin","Swathi"),
  Maths = c(72,84,65,91,78,88,69,95,74,82),
  Science = c(68,80,70,89,76,85,72,93,75,79),
  English = c(75,78,72,94,80,86,70,90,77,81)
)
mean_marks <- sapply(students[,2:4], mean)
median_marks <- sapply(students[,2:4], median)
sd_marks <- sapply(students[,2:4], sd)
students$Total <- rowSums(students[,2:4])
top_student <- students[which.max(students$Total), ]
avg_math <- mean(students$Maths)
above_avg_math <- students[students$Maths > avg_math, ]
mean_marks
