Question 4: Employee Salary Analysis (Updated Data)
employees <- data.frame(
  EmpID = 201:210,
  Name = c("Karthi","Leela","Mohan","Nisha","Omkar","Pallavi","Qadir","Rekha","Sameer","Tanvi"),
  Dept = c("Sales","IT","HR","Sales","Finance","IT","HR","Finance","Sales","IT"),
  Salary = c(28000,42000,31000,35000,47000,39000,32000,45000,36000,41000)
)
dept_stats <- aggregate(Salary ~ Dept, data=employees, function(x) c(Mean=mean(x), Median=median(x)))
dept_stats <- do.call(data.frame, dept_stats)
overall_avg <- mean(employees$Salary)
high_earners <- employees[employees$Salary > overall_avg, ]
dept_stats
high_earners

 Question 5: Online Store Customer Ratings (Updated Data)
ratings <- data.frame(
  ProductID = 11:20,
  Product = c("TV","Fridge","AC","Mixer","Iron","Fan","Cooler","Heater","Vacuum","Juicer"),
  Rating = c(5,4,4,3,5,4,3,4,5,4)
)
mean_rating <- mean(ratings$Rating)
median_rating <- median(ratings$Rating)
var_rating <- var(ratings$Rating)
getmode <- function(v) {
  uniqv <- unique(v)
  uniqv[which.max(tabulate(match(v, uniqv)))]
}
mode_rating <- getmode(ratings$Rating)
top_rated <- ratings[ratings$Rating > 4, ]
mean_rating
median_rating
mode_rating
var_rating
top_rated
